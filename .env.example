# Firebase Web SDK (client) — all NEXT_PUBLIC_*
NEXT_PUBLIC_FIREBASE_API_KEY=replace-me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=knowlify-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=knowlify-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=knowlify-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
NEXT_PUBLIC_FIREBASE_APP_ID=replace-me

# Set to "true" for local emulator development
NEXT_PUBLIC_USE_EMULATORS=true

# Firebase Admin SDK (server) — DO NOT prefix with NEXT_PUBLIC
FIREBASE_ADMIN_PROJECT_ID=knowlify-dev
FIREBASE_ADMIN_CLIENT_EMAIL=replace-me@knowlify-dev.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
